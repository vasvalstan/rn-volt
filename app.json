{
  "expo": {
    "name": "test",
    "slug": "test",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "test",
    "userInterfaceStyle": "automatic",
      "ios": {
        "appleTeamId": "27W785VCL2",
        "deploymentTarget": "16.4",
        "icon": "./assets/expo.icon",
        "entitlements": {
          "com.apple.developer.family-controls": true,
          "com.apple.developer.family-controls.app-and-website-usage": true,
          "com.apple.security.application-groups": [
            "group.com.volt.screentime"
          ]
        },
        "infoPlist": {
        "NSCameraUsageDescription": "Volt uses your camera to detect push-up and squat reps.",
        "NSMicrophoneUsageDescription": "Volt uses your microphone for voice notes and real-time coaching.",
        "NSLocationWhenInUseUsageDescription": "Volt tracks your walk/run to verify distance and reward you with Unlock Minutes.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.stanciuvalentin.test"
    },
    "android": {
      "versionCode": 2,
      "package": "com.stanciuvalentin.test",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-audio",
      "expo-image",
      "@config-plugins/react-native-webrtc",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      "./plugins/withAndroidBuildMemory",
      "./plugins/withMediaPipeIosLinking",
      [
        "react-native-device-activity",
        {
          "appleTeamId": "27W785VCL2",
          "appGroup": "group.com.volt.screentime"
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Volt uses your camera to detect push-up and squat reps."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Volt tracks your walk/run to verify distance and reward you with Unlock Minutes."
        }
      ],
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsImpl": "mapbox"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "com.stanciuvalentin.test.ShieldConfiguration",
                  "targetName": "ShieldConfiguration",
                  "entitlements": {
                    "com.apple.developer.family-controls": true,
                    "com.apple.developer.family-controls.app-and-website-usage": true,
                    "com.apple.security.application-groups": [
                      "group.com.volt.screentime"
                    ]
                  }
                },
                {
                  "bundleIdentifier": "com.stanciuvalentin.test.ShieldAction",
                  "targetName": "ShieldAction",
                  "entitlements": {
                    "com.apple.developer.family-controls": true,
                    "com.apple.developer.family-controls.app-and-website-usage": true,
                    "com.apple.security.application-groups": [
                      "group.com.volt.screentime"
                    ]
                  }
                },
                {
                  "bundleIdentifier": "com.stanciuvalentin.test.ActivityMonitorExtension",
                  "targetName": "ActivityMonitorExtension",
                  "entitlements": {
                    "com.apple.developer.family-controls": true,
                    "com.apple.developer.family-controls.app-and-website-usage": true,
                    "com.apple.security.application-groups": [
                      "group.com.volt.screentime"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "f4cdae21-62cf-4727-8458-2d42c9eabed6"
      }
    },
    "owner": "stanciuvalentin"
  }
}
