{
  "name": "test",
  "main": "index.js",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "dev": "bash scripts/dev.sh",
    "start:mcp": "EXPO_UNSTABLE_MCP_SERVER=1 expo start",
    "start:tunnel": "expo start --tunnel",
    "start:dev-client": "expo start --dev-client",
    "start:dev-client:tunnel": "expo start --dev-client --tunnel",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "android:release": "expo run:android --variant release",
    "android:release:apk": "cd android && ./gradlew assembleRelease",
    "ios": "expo run:ios",
    "screenshot:ipad-13": "bash scripts/capture-ipad-13-screenshot.sh",
    "android:emu:s25": "bash scripts/android-avd/start-s25.sh",
    "android:emu:tab": "bash scripts/android-avd/start-tab-s8u.sh",
    "appscreens:start-all": "bash scripts/appscreens/start-all-four.sh",
    "appscreens:run-ios-both": "bash scripts/appscreens/run-ios-both.sh",
    "appscreens:capture:ios": "bash scripts/appscreens/capture-ios.sh",
    "appscreens:capture:ios:iphone": "bash scripts/appscreens/capture-ios-iphone.sh",
    "appscreens:capture:ios:ipad": "bash scripts/appscreens/capture-ios-ipad.sh",
    "appscreens:capture:android": "bash scripts/appscreens/capture-android.sh",
    "appscreens:capture:android:phone": "bash scripts/appscreens/capture-android-phone.sh",
    "appscreens:capture:android:tablet": "bash scripts/appscreens/capture-android-tablet.sh",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run test:gamification && npm run test:gps && npm run test:voice-quota",
    "test:gamification": "node --experimental-strip-types shared/gamification.test.mjs",
    "test:gps": "node --experimental-strip-types shared/gpsTracking.test.mjs",
    "test:voice-quota": "node --experimental-strip-types shared/voiceQuota.test.mjs",
    "eas:build:dev": "npx eas-cli build --profile development",
    "eas:build:preview": "npx eas-cli build --profile preview",
    "eas:build:prod": "npx eas-cli build --profile production",
    "eas:submit": "npx eas-cli submit"
  },
